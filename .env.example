# ============================================
# AtomQuest - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --- Neon DB (PostgreSQL) ---
# Get these from https://console.neon.tech → Your Project → Connection Details
DB_HOST=ep-xxxxx-xxxxx-xxxxxx.us-east-2.aws.neon.tech
DB_PORT=5432
DB_NAME=atomquest
DB_USERNAME=atomquest_owner
DB_PASSWORD=your_neon_password_here
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=require

# --- Redis ---
# Local Docker Redis (default) or a cloud Redis URL
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-256-bits
JWT_EXPIRATION_MS=86400000

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# --- AI / LLM (for RAG & SMART Goals) ---
# OpenAI or Gemini API key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Or for Gemini:
# GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXX

# --- Email (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- Frontend ---
VITE_API_URL=http://localhost:8080/api
VITE_WS_URL=ws://localhost:8080/ws
